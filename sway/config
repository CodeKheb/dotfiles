# dependencies
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK
exec systemctl --user start sway-session.target
exec_always export PATH=$HOME/bin:$PATH

set $mod Mod4

# launch
bindsym $mod+v exec ~/projects/dotfiles/rofi/projects.sh
bindsym $mod+Return exec kitty
bindsym $mod+i exec kitty nmtui
bindsym $mod+Space exec rofi -show drun -theme ~/projects/dotfiles/rofi/launchers/type-6/style-7.rasi

# web browser
bindsym $mod+b exec ~/projects/dotfiles/website-picker/website-picker.sh 

# toggle waybar
bindsym $mod+t exec sh -c 'pgrep -x waybar >/dev/null && pkill waybar || waybar &'

bindsym $mod+q kill

# tiling
bindsym $mod+h focus left
bindsym $mod+l focus right
bindsym $mod+j focus down
bindsym $mod+k focus up

bindsym $mod+Shift+h move left
bindsym $mod+Shift+l move right
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up

bindsym $mod+Shift+t floating toggle

# workspace
set $ws1 "main"
set $ws2 "second"
set $ws3 "third"
set $ws4 "fourth"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4

bindsym $mod+Shift+1 move container to workspace $ws1; workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2; workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3; workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4; workspace $ws4

bindsym $mod+Ctrl+l workspace next
bindsym $mod+Ctrl+h workspace prev

# screenshot
bindsym Print exec grim -g "$(slurp)" - | wl-copy

# poweroff
bindsym $mod+Shift+Delete exec systemctl reboot 
bindsym $mod+Delete exec systemctl poweroff

# volume
bindsym F2 exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym F3 exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+

# brightness
bindsym F5 exec brightnessctl set 5%-
bindsym F6 exec brightnessctl set 5%+

# borders
default_border pixel 1
default_floating_border pixel 0

# gaps
gaps inner 0
gaps outer 0

# focus
client.focused          #5f5f5f #111111 #ffffff #5f5f5f #5f5f5f
client.unfocused        #1a1a1a #111111 #888888 #1a1a1a #1a1a1a

# input rebinds
input * xkb_options caps:escape
input type:touchpad {
    natural_scroll enabled
}

# monitor
output HDMI-A-2 enable
